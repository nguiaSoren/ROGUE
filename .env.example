# ---------- LLM provider keys ----------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...
# Gemini has a DIRECT adapter (`src/rogue/adapters/gemini.py`) — it reads
# GEMINI_API_KEY first, then GOOGLE_API_KEY as a fallback. Set whichever you
# have if you target `google/*` models directly. Mistral has no direct
# integration: `target_panel.py` routes `mistralai/*` ids through OpenRouter
# (above), so no MISTRAL_API_KEY is needed.
GEMINI_API_KEY=
GOOGLE_API_KEY=

# ---------- Bright Data ----------
BRIGHTDATA_API_KEY=brd-...
BRIGHTDATA_SERP_ZONE=rogue_serp
BRIGHTDATA_UNLOCKER_ZONE=rogue_unlocker
BRIGHTDATA_BROWSER_ZONE=rogue_browser
BRIGHTDATA_REDDIT_DATASET_ID=gd_lvz...           # find on Day 1 in BD dashboard
BRIGHTDATA_X_POSTS_DATASET_ID=gd_lwxkl4...        # find on Day 1
BRIGHTDATA_HUGGINGFACE_DATASET_ID=                # may not exist; leave blank if so
# Scraping Browser credentials (LeakHub + any other authed sites). Pulled
# by `bright_data_client.scrape_browser`.
BRIGHTDATA_BROWSER_CUSTOMER_ID=
BRIGHTDATA_BROWSER_PASSWORD=

# ---------- Scraper-agnostic harvest (run WITHOUT Bright Data) ----------
# ROGUE's harvest routes every fetch through a backend-agnostic Fetcher. Bright Data is the
# default/first backend (above); these let you run the harvest on free/keyless backends instead.
# Nothing here is required — leave blank to use Bright Data, or set them to run BD-free.
#
# Preference order (csv of backend names). Default puts the robust scrapers ahead of plain httpx:
#   brightdata > crawl4ai > firecrawl > direct > ddg > hf_api > reddit_oauth > playwright > x_besteffort
# ROGUE_FETCHER_ORDER=crawl4ai,direct,ddg,hf_api,reddit_oauth,playwright,x_besteffort
#
# Crawl4AI (OSS, local, free) — no env needed; install the extra: pip install "rogue[crawl4ai]"
#   then download the browser: crawl4ai-setup  (or: playwright install chromium)
#
# Local PDF parsing — ALWAYS on, no env/extra needed (pypdf floor, a core dep). The preferred PDF
#   parser (BD/direct return raw bytes; Firecrawl is rate-limited). For richer markdown on complex
#   layouts/tables, upgrade with: pip install "rogue[pdf]"  (adds pymupdf4llm, used automatically).
#
# SearXNG (OSS, self-hosted, free + UNLIMITED) — preferred SERP + image search when set. Point at
#   your instance (must have JSON output enabled in settings.yml: search.formats: [html, json]):
# SEARXNG_URL=http://localhost:8888
#
# Universal harvest proxy — route ALL origin-site scraping (direct, ddg, local_pdf, crawl4ai,
#   playwright) through one external proxy pool, e.g. cheap residential (Webshare/IPRoyal/your own) —
#   a provider-agnostic substitute for Bright Data's bundled residential network. Use http(s):// (not
#   SOCKS5-with-auth; a rotating gateway endpoint works). Does NOT touch LLM/judge or BD calls.
# ROGUE_PROXY_URL=http://user:pass@p.webshare.io:80
#
# Firecrawl — self-host (free) OR cloud (paid) OR keyless free tier. Set ONE:
# FIRECRAWL_BASE_URL=http://localhost:3002          # self-hosted instance (free, AGPL)
# FIRECRAWL_API_KEY=fc-...                           # cloud (https://api.firecrawl.dev)
# FIRECRAWL_KEYLESS=1                                # keyless free tier — no account, no key
#   (opt-in; rate-limited, ideal for demo/low-volume; a real anti-bot UNLOCK/BROWSER
#    backend with zero signup. Set FIRECRAWL_API_KEY instead to scale.)
#
# Reddit — the free path needs a (free) Reddit "script" app: https://www.reddit.com/prefs/apps
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=rogue-red-team/0.1 by u/your_username   # Reddit 429s without a descriptive UA
#
# X / Twitter has no reliable keyless path — the x_besteffort backend is experimental + self-capped.
# ROGUE_X_MAX_POSTS=200                               # hard ceiling per run (clamped to <=200)

# ---------- LeakHub.ai storage state (auth) ----------
# LeakHub is a Vite-built React SPA whose auth lives in localStorage
# (Convex backend → JWT under `__convexAuthJWT_<deployment>`), NOT in
# cookies — verified 2026-05-26: even when signed in the site sets zero
# cookies. So the cookie-only approach can't work; we need Playwright's
# full `storage_state` (cookies + per-origin localStorage in one JSON).
#
# Capture once after signing in via GitHub:
#   uv run python scripts/_capture_leakhub_storage.py
# That writes `leakhub_storage_state.json` to the repo root. Then set:
#   LEAKHUB_STORAGE_STATE=./leakhub_storage_state.json
# Inline JSON is also accepted:
#   LEAKHUB_STORAGE_STATE='{"cookies":[],"origins":[{"origin":"https://leakhub.ai","localStorage":[{"name":"...","value":"..."}]}]}'
# Leave blank to disable (plugin reports a clear error in call_errors).
LEAKHUB_STORAGE_STATE=

# ---------- Database ----------
DATABASE_URL=postgresql+psycopg://rogue:rogue_dev_password@localhost:5432/rogue
# Tests use a SEPARATE database (`rogue_test`) so pytest's alembic
# upgrade→downgrade-base round-trip in test_smoke.py never destroys the
# dev DB. Created by `docker/init-test-db.sh` on fresh volumes; for
# existing volumes, run:
#   docker compose exec -T postgres psql -U rogue -d rogue -c "CREATE DATABASE rogue_test;"
TEST_DATABASE_URL=postgresql+psycopg://rogue:rogue_dev_password@localhost:5432/rogue_test
# Live Neon DB the deployed dashboard reads. When set, the pipeline scripts
# (harvest_once / reproduce_once / rejudge_batch) AUTO-PUSH their results here
# at the end — data-only, no LLM/BD spend — so a local re-grade surfaces on the
# live site with no manual step. Unset = local-only (no sync). Manual:
#   uv run python scripts/ops/sync_to_neon.py
# NEON_DATABASE_URL=postgresql+psycopg://USER:PASS@HOST/neondb?sslmode=require
# Local Docker Postgres URL — read by scripts/ops/sync_db.sh, which syncs between the
# local DB and Neon (DATABASE_URL = Neon target, LOCAL_DATABASE_URL = local source).
# LOCAL_DATABASE_URL=postgresql+psycopg://rogue:rogue_dev_password@localhost:5432/rogue

# ---------- Frontend on-demand revalidation (optional) ----------
# After a harvest/reproduce run syncs new data to Neon, it POSTs the frontend's
# /api/revalidate route so the statically-cached dashboard pages regenerate
# IMMEDIATELY instead of waiting out the ~5-min ISR window. Both vars must be set
# or the ping is skipped (the pages still refresh on the normal ISR cycle).
# REVALIDATE_TOKEN must MATCH the value set in the Vercel project env.
# FRONTEND_REVALIDATE_URL=https://rogue-eosin.vercel.app/api/revalidate
# REVALIDATE_TOKEN=  # a long random string; also set in Vercel → Settings → Environment Variables

# ---------- Harvest toggles (optional; defaults shown) ----------
# HARVEST_INGEST_IMAGES=1        # 0 disables multimodal image ingestion (Feature A)
# MEDIA_INGEST_MAX_PER_DOC=4
# MEDIA_INGEST_MAX_TOTAL=60
# HARVEST_FOLLOW_LINKS=1         # 0 disables post→link following (Feature C)
# EXTRACTION_CONCURRENCY=3       # parallel extraction-agent calls during harvest
# BD async-snapshot poll timeout. The X discover-by-profile scraper can take
# 15-30+ min, exceeding the 600s default — bump it when using --x-handles:
# BRIGHTDATA_POLL_TIMEOUT_SECONDS=1800
# BRIGHTDATA_POLL_INTERVAL_SECONDS=10

# ---------- Slack demo webhook ----------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# Surface-1 Slack delivery (build-06 §8): the bot's OAuth token + the app signing secret.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ---------- Model selection ----------
# Every model below is provider/model and configurable — you are NOT locked to one model or API.
EXTRACTION_MODEL=anthropic/claude-haiku-4-5
JUDGE_MODEL=anthropic/claude-sonnet-4-6
# Judge fallback when the primary judge call errors/parses-fails (judge.py).
JUDGE_FALLBACK_MODEL=deepseek/deepseek-v4-flash
# Run the judge (or extraction) on a LOCAL model to keep the loop ~$0:
#   JUDGE_MODEL=openai/llama3.1   OPENAI_BASE_URL=http://localhost:11434/v1   OPENAI_API_KEY=ollama
# (the OpenAI SDK honors OPENAI_BASE_URL, so openai/* routes to any OpenAI-compatible endpoint).
# CAVEAT: ROGUE's judge credibility (the JBB/κ/SHIP calibration in docs/judge-calibration.md) is
# validated against the DEFAULT judge. A local/open judge is UNCALIBRATED — it tends to under-call
# breaches — until you re-run scripts/calibration/ against it. Free judge, yes; trusted judge, re-cal.
# OPENAI_BASE_URL=http://localhost:11434/v1
# Q17 — local-first extraction CASCADE (off by default). When ON, a cheap local
# model extracts first and only grounded, schema-valid primitives are accepted;
# everything else (abstention / invalid / ungrounded payload) escalates to the
# Haiku extractor above — so it can only ever SAVE a Haiku call, never DROP an
# attack. Needs OPENAI_BASE_URL set (the local endpoint). MEASURE first with
# scripts/extract/eval_extractor_fields.py — off-the-shelf qwen2.5 at 3B/14B/32B
# ALL score recall 0/2 on the fixtures; a real saving needs a fine-tuned
# local extractor. Uses a local/ json-mode branch (the strict openai/ parse path
# can't compile the AttackPrimitive grammar on Ollama). See docs/research/extraction_cascade.md.
# ROGUE_EXTRACT_CASCADE=on
# ROGUE_EXTRACT_LOCAL_MODEL=local/qwen2.5:3b
# ROGUE_EXTRACT_GROUNDING_THRESHOLD=0.15   # anti-fabrication floor, NOT a correctness gate
EMBEDDING_MODEL=text-embedding-3-small
# §10.9 escalation planner backbone. Default is a PERMISSIVE Mistral (OpenRouter):
# aligned planners refuse to author escalation plans for harvested jailbreak
# directives, capping candidate validity at ~22%; Mistral took it to 100% and
# unlocked graduations the aligned planner made unreachable. Architecture: safe
# judge + permissive planner + safe target. Override per-run via --escalate-planner-model.
ROGUE_ESCALATION_PLANNER=mistralai/mistral-small-2603

# ---------- Run-tuning ----------
# Trials-per-attack and dedup cosine threshold are NOT env-configurable: trials
# come from the --n-trials CLI flag / SDK arg (default 1), and the dedup
# threshold is the module constant DEFAULT_DEDUP_COSINE_THRESHOLD=0.92 in
# syntactic_mutation.py. Only BREACH_RATE_THRESHOLD is read from the env.
# Primitives with max(any_breach_rate) >= this count as "breaching" in the
# threat-brief diff (threat_brief.py).
BREACH_RATE_THRESHOLD=0.4

# ---------- MCP server transport ----------
# Default stdio = the subprocess Claude Desktop spawns (leave unset for that).
# Set streamable-http (or legacy sse) to serve the same tools over HTTP for
# remote clients (Cursor / Windsurf / hosted), on a dedicated port alongside
# the FastAPI dashboard (8000). Host defaults to 127.0.0.1; 0.0.0.0 exposes off-box.
ROGUE_MCP_TRANSPORT=stdio
ROGUE_MCP_PORT=8001
ROGUE_MCP_HOST=127.0.0.1
# Org bound to the live MCP scan-action tools registered on the FastAPI app
# (api/main.py). Never an LLM tool arg — the server pins it here. Default "demo".
# ROGUE_MCP_ORG_ID=demo

# ---------- Hosted platform (/v1 SaaS layer) ----------
# Fernet key encrypting tenant target credentials + stored integration secrets
# at rest (rogue.platform.secrets / integration_store). UNSET = hosted scans
# persist the raw target API key in scan_jobs and integrations fall back to
# raw-arg destinations (a startup WARNING fires). Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SECRET_ENCRYPTION_KEY=
# Run the scan worker inside the API process (the $0 single-service path) instead
# of a separate `python -m rogue.platform.worker`. Truthy = 1/true/yes/on.
# ROGUE_INPROCESS_WORKER=0
# Future Redis-backed queue (rogue.config seam). Unused today; Postgres is the queue.
# REDIS_URL=

# ---------- Dashboard / API behaviour ----------
# Which date the dashboard report defaults to when none is requested
# (api/main.py). "most-recent" picks the latest brief; or an ISO YYYY-MM-DD.
# REPORT_DEFAULT_DATE=most-recent

# ---------- Escalation ladder + scheduler tuning (optional; defaults shown) ----------
# Ladder traversal order (ladder_priors.py): contextual | canonical | discovery |
# viability | starvation | fixed. Default contextual (the cross-tier + vendor-
# conditioned scheduler, §10.10; shipped default 2026-06-06, commit e279701 —
# rank 22->11, ASR 50%->60%, cost/success 1.25->0.74 on Claude Haiku). Set
# ROGUE_LADDER_ORDER=canonical for an instant rollback to the deterministic greedy reorder.
# ROGUE_LADDER_ORDER=contextual
# ROGUE_LADDER_DISCOVERY_C=0.5            # UCB exploration constant
# ROGUE_LADDER_EXPLORE_WEIGHT=0.5
# ROGUE_LADDER_FRESHNESS_TAU_DAYS=14      # freshness decay time-constant
# ROGUE_LADDER_FRESHNESS_WEIGHT=0.5
# ROGUE_LADDER_STARVATION_WEIGHT=1.0
# Contextual-mode blend weights (ladder_priors.py). MUST sum to 1.0 (asserted at
# import — a non-1.0 sum raises). Global-pooled + vendor-conditioned + family.
# ROGUE_LADDER_BLEND_W_GLOBAL=0.5
# ROGUE_LADDER_BLEND_W_VENDOR=0.3
# ROGUE_LADDER_BLEND_W_FAMILY=0.2
# ---------- Q11 system-prompt-transfer survival gate (survival/gate.py) ----------
# Rank harvested attacks by predicted cross-config survival so a scan fires the likely
# survivors first and defers the rest. OFF by default (unset) → today's fire order is
# byte-identical. Train the model first: scripts/reproduce/train_survival_model.py.
# See docs/research/survival_predictor.md.
# ROGUE_SURVIVAL_ORDER=off                 # on | off  (on requires a trained model artifact)
# ROGUE_SURVIVAL_MODEL=data/models/survival_predictor.json
# ROGUE_SURVIVAL_MIN_SUPPORT=8             # families below this many primitives → fire-all (drift-guard)
# ROGUE_SURVIVAL_FIRE_ALL_FRAC=0.15        # deterministic fraction of skips force-kept (continuous validation)
# ROGUE_SURVIVAL_SKIP_THRESHOLD=           # optional score floor below which an attack is skippable
# Pre-fire success scorer (Q7) — score each (attack × target) with a calibrated P(breach) and SKIP the
# predicted misses before firing (spares target + judge calls). Off by default → every primitive fired,
# byte-identical. Train the model first: scripts/reproduce/train_prefire_scorer.py. Drift-guard fires-all
# novel/low-support families. Wired into run_scan / scan_endpoint / reproduce_once (--prefire-skip).
# See docs/research/prefire_scorer.md.
# ROGUE_PREFIRE_SKIP=off                    # on | off  (on requires a trained model artifact)
# ROGUE_PREFIRE_MODEL=data/models/prefire_scorer.json
# ROGUE_PREFIRE_THRESHOLD=                  # skip below this calibrated P(breach); default = model's 95%-recall point
# ROGUE_PREFIRE_MIN_SUPPORT=8               # families below this many primitives → fire-all (drift-guard)
# ROGUE_PREFIRE_FIRE_ALL_FRAC=0.15          # deterministic fraction of skips force-fired (continuous validation)
# ROGUE_PREFIRE_EMBED=on                    # on | off — compute serve-time embeddings (off → structural-only score)
# M2S single-turn consolidation (Q14) — fold a multi-turn primitive's turns into ONE structured
# single-turn prompt (Ha et al. 2503.04856: Hyphenize/Numberize/Pythonize) so it fires at 1× trial
# instead of K sequential victim calls. Off by default → multi-turn fires as a real back-and-forth,
# byte-identical. Wired into run_scan / scan_endpoint / reproduce_once (--m2s-consolidate).
# See docs/research/m2s_consolidation.md.
# ROGUE_M2S=off                             # on | off
# ROGUE_M2S_METHOD=pythonize                # hyphenize | numberize | pythonize (default; strongest single method)
# SPRT early-stopping (Q6) — replace a fixed n_trials per cell with Wald's sequential test: stop as
# soon as the breach/no-breach decision is statistically clear. Off by default → today's fixed-n loop.
# Wired into run_scan / scan_endpoint / generator_sweep / reproduce_once. See docs/research/sprt_early_stopping.md.
# ROGUE_SPRT=off                           # on | off
# ROGUE_SPRT_P0=0.25                        # H0 breach prob (below the breach line)
# ROGUE_SPRT_P1=0.55                        # H1 breach prob (above it)
# ROGUE_SPRT_ALPHA=0.05                     # Type I error → Wald bound A=(1-β)/α
# ROGUE_SPRT_BETA=0.05                      # Type II error → Wald bound B=β/(1-α)
# ROGUE_SPRT_MAX_TRIALS=12                  # truncation cap; borderline cells run to here then use rate≥threshold
# ROGUE_SPRT_BATCH=2                        # trials fired concurrently per turn (1 = pure sequential)
# Cascade judge (Q2) — grade every trial with the FREE heuristic first, escalate to the paid LLM judge
# only when it isn't a confident non-breach. Off by default → today's single-judge grading. Wired into
# run_scan / scan_endpoint / reproduce_once (inert on --judge-batch). See docs/research/cascade_judge.md.
# ROGUE_CASCADE_JUDGE=off                   # on | off
# ROGUE_CASCADE_TAU=0.7                      # heuristic confidence gate; short-circuit only if conf ≥ τ
# ROGUE_CASCADE_ESCALATE_ON_BREACH=on       # on → never assert a breach from the free tier (safety rail)
# Reference-anchored grading (Q1) — prepend K human-verified verdict exemplars to the judge rubric
# (Krumdick's "give the judge a verified reference" fix, translated to a breach judge). Off by default
# (K=0) → self.prompt is BYTE-IDENTICAL to today at every scan surface. K>0 injects the block; whether it
# helps a smaller JUDGE_MODEL is measured by the judge-shrink A/B, never assumed. See
# docs/research/judge_shrink_ab.md and scripts/calibration/judge_shrink_ab.py (the $0 decision harness).
# ROGUE_JUDGE_REFERENCE_K=0                  # 0 = off; N>0 = inject N balanced verified exemplars
# Noise-corrected calibration (Q4) — de-bias a judge-labelled breach rate against the judge's own
# TPR̂/FPR̂ (from the human-labelled calibration set) and certify it (Feng/Lee). Off by default → the
# calibration reports are byte-identical to today. When on, a `noise_corrected` block is added to the
# report. See docs/research/noise_corrected_calibration.md.
# ROGUE_NOISE_CORRECTED_CALIBRATION=off    # on | off
# ROGUE_NOISE_CORRECT_ALPHA=0.20            # certification tolerance α (H0: true breach rate ≥ α)
# ROGUE_NOISE_CORRECT_ZETA=0.05             # one-sided Type-I level ζ (also sets the 1−ζ CI)
# Pre-fire prompt pruning (Q12/Q10) — in the escalation search, skip a paid rollout when the candidate
# PROMPT is cosine ≥ threshold to one already fired THIS search (TAP prune-before-fire ported to
# ROGUE's per-expansion loop; near-dup criterion reuses dedupe's 0.92). Off by default → the searcher
# fires every expansion exactly as today. Only active inside the opt-in search subsystem
# (search_escalate / harden_from_remediation / the ab.py A/B). See docs/research/prefire_pruning.md.
# ROGUE_SEARCH_PRUNE=off                    # on | off  (on also needs an embed_fn on the search path)
# ROGUE_SEARCH_PRUNE_THRESHOLD=0.92         # cosine cut for a near-duplicate skip (reuses dedupe's 0.92)
# ROGUE_SEARCH_PRUNE_LAMBDA=0.0             # EvoJail soft reward F(p)=S(p)+λ·D(p|P); 0 = hard-skip only
# Technique-retrieval gating (escalation_ladder.py; the system is DEPLOYED-INACTIVE).
# Leave both 0 until Recall@50 >= 80% (scripts/benchmark/retrieval_eval.py --live). TOPK>0
# activates top-K technique intersection; SHADOW=1 logs retrieval without using it.
# ROGUE_RETRIEVAL_TOPK=0
# ROGUE_RETRIEVAL_SHADOW=0
# Slot-fill the escalation planner's templates (escalation_planner.py). Default on ("1").
# ROGUE_ESCALATION_SLOT_FILL=1
# "Strict" mode for each augmentation stage — set to "1" to RAISE on a generation
# failure instead of degrading gracefully (debugging aid; leave unset in prod).
# ROGUE_ESCALATION_STRICT, ROGUE_MUTATION_STRICT, ROGUE_PAIR_STRICT, ROGUE_PERSONA_STRICT
# Self-growing repertoire — graduation scheduler (growth_scheduler.py).
# GROWTH_MIN_POOL=5
# GROWTH_MIN_AGE_DAYS=0
# GROWTH_K=5
# Candidate strategy lifecycle (strategy_lifecycle.py).
# STRATEGY_MIN_TRIALS=5
# STRATEGY_TTL_DAYS=30
# STRATEGY_MIN_AGE_DAYS=7
# STRATEGY_TEMPLATES=                      # optional path to extra strategy templates
# CAND_LADDER_SCOPE=run                    # candidate-ladder scope: run | <other>
# CAND_LADDER_CAP=3                        # max candidate strategies injected per ladder
# Secondary Slack webhook for the iterative (PAIR) attacker breach alerts
# (iterative_attacker.py) — distinct from SLACK_WEBHOOK_URL above (threat-brief alerts).
# ROGUE_SLACK_WEBHOOK_URL=
# PAIR (iterative attacker) spend caps (iterative_attacker.py). Per-primitive cap
# stops one hard primitive eating the budget; per-day cap aborts the run. Defaults shown.
# ROGUE_PAIR_PER_PRIMITIVE_BUDGET_USD=1.50
# ROGUE_PAIR_PER_DAY_BUDGET_USD=20.00

# ---------- Observability / production (optional; every var no-op when unset) ----------
# Structured logging (api/observability.py). LOG_JSON=1 emits one-line JSON records.
# LOG_LEVEL=INFO
# LOG_JSON=0
# Sentry error monitoring — no-op unless SENTRY_DSN is set.
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# ROGUE_ENV=production                 # Sentry environment tag
# API rate limits (slowapi; no-op if slowapi absent). Public reads vs /v1 scans.
# RATE_LIMIT_DEFAULT=120/minute
# RATE_LIMIT_SCANS=10/minute

# ---------- Ops / tooling scripts (optional; only the named script reads each) ----------
# HuggingFace token — scripts/harvest/analyze_hf_datasets.py (required there) and
# scripts/harvest/export_huggingface_dataset.py (optional, for pushing a dataset).
# HF_TOKEN=hf_...
# Bearer key for a custom-HTTP scan target — scripts/reproduce/scan_endpoint.py
# (falls back to OPENAI_API_KEY if unset).
# CUSTOM_API_KEY=
# Auto-publish analytics at the end of scripts/ops/build_analytics.py. Truthy = "1".
# ROGUE_AUTO_PUBLISH_ANALYTICS=0

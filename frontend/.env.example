# ROGUE frontend (Next.js) — environment variables.
# Copy to .env.local for local dev, or set these in Vercel → Project → Settings
# → Environment Variables for the deployed site. NEXT_PUBLIC_* vars are baked
# into the build (client-visible); the rest are server-only.

# Base URL of the ROGUE backend API the dashboard reads from.
# Local default (when unset): http://localhost:8000. On Vercel set to the live
# API, e.g. https://rogue-private.onrender.com.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Optional Calendly embed URL for the /request-demo scheduler. When unset, the
# inline Calendly iframe is omitted and the page falls back to the lead form.
NEXT_PUBLIC_CALENDLY_URL=

# Commercial layer toggle. "true" reveals the commercial pages (/pricing,
# /enterprise, /security) + pricing CTAs. Anything else (the default) runs the
# honest hiring mode: those pages 404 and CTAs route to /early-access.
NEXT_PUBLIC_SHOW_COMMERCIAL=false

# Shared secret guarding the on-demand revalidation endpoint
# (POST /api/revalidate, header x-revalidate-token). Server-only. Fails closed:
# if unset, the endpoint rejects all requests.
REVALIDATE_TOKEN=

# Full URL of this frontend's revalidate endpoint, called by the backend after a
# new run lands to purge the ISR cache early, e.g.
# https://rogue-eosin.vercel.app/api/revalidate. Server-only.
FRONTEND_REVALIDATE_URL=
